# Microsoft Foundry / Azure OpenAI inference endpoint.
# Supported examples:
# https://YOUR_RESOURCE_NAME.openai.azure.com
# https://YOUR_RESOURCE_NAME.openai.azure.com/openai/v1
FOUNDRY_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com

# Server-side API key. Never prefix this variable with NEXT_PUBLIC_.
FOUNDRY_API_KEY=replace-with-your-foundry-api-key

# The name of the chat model deployment configured in Microsoft Foundry.
FOUNDRY_DEPLOYMENT_NAME=replace-with-your-deployment-name
